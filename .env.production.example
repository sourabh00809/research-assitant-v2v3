AI_SCIENTIST_DOMAIN=research.example.com
AI_SCIENTIST_PUBLIC_BASE_URL=https://research.example.com
AI_SCIENTIST_ENV=production
AI_SCIENTIST_STORE_BACKEND=postgres

# Replace every secret before first boot.
POSTGRES_PASSWORD=replace-with-32-plus-random-chars
AI_SCIENTIST_APP_PASSWORD=replace-with-operator-password
AI_SCIENTIST_ADMIN_EMAIL=admin@example.com
AI_SCIENTIST_JWT_SECRET=replace-with-64-plus-random-chars

# Supabase project reference — used to construct DATABASE_URL.
# Find it in your Supabase dashboard under Project Settings → API.
SUPABASE_PROJECT_REF=your-project-ref

# DATABASE_URL is auto-constructed from SUPABASE_PROJECT_REF and POSTGRES_PASSWORD.
# Override this if you use a custom connection string.
DATABASE_URL=postgresql+psycopg://postgres:${POSTGRES_PASSWORD}@db.${SUPABASE_PROJECT_REF}.supabase.co:5432/postgres

# Required for frontend builds (Next.js inlines at build time).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

AI_SCIENTIST_JWT_TTL_SECONDS=604800
AI_SCIENTIST_COOKIE_SECURE=true
AI_SCIENTIST_COOKIE_SAMESITE=lax

AI_SCIENTIST_SANDBOX_BACKEND=docker
AI_SCIENTIST_SANDBOX_IMAGE=python:3.11-slim
AI_SCIENTIST_SANDBOX_CPU_QUOTA=50000
AI_SCIENTIST_SANDBOX_MEMORY_MB=512
AI_SCIENTIST_WORKER_CONCURRENCY=2

AI_SCIENTIST_AI_PROVIDER=deterministic
AI_SCIENTIST_MODEL=gpt-4.1-mini
AI_SCIENTIST_LIVE_SEARCH=0
AI_SCIENTIST_EMBEDDING_PROVIDER=local
AI_SCIENTIST_EMBEDDING_MODEL=deterministic-hash-v1
AI_SCIENTIST_PUBMED_ENABLED=false
AI_SCIENTIST_HF_ENABLED=false
AI_SCIENTIST_PWC_ENABLED=false
AI_SCIENTIST_MAX_PAPERS=6
AI_SCIENTIST_MAX_CHUNKS=8

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_STORAGE_BUCKET=research-assets

GROQ_API_KEY=
TAVILY_API_KEY=
UNSTRUCTURED_API_KEY=

AI_SCIENTIST_OPENALEX_ENABLED=true
AI_SCIENTIST_CORE_ENABLED=true
AI_SCIENTIST_CROSSREF_ENABLED=true
AI_SCIENTIST_GROQ_ENABLED=true

# Optional provider keys
# OPENAI_API_KEY=
# NCBI_API_KEY=
# CORE_API_KEY=
# HUGGINGFACE_API_TOKEN=
# PAPERSWITHCODE_API_KEY=

# Clerk (Next.js public — inlined at build time)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

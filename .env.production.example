AI_SCIENTIST_DOMAIN=research.example.com
AI_SCIENTIST_PUBLIC_BASE_URL=https://research.example.com
AI_SCIENTIST_ENV=production
AI_SCIENTIST_STORE_BACKEND=postgres

# Replace every secret before first boot.
POSTGRES_PASSWORD=replace-with-32-plus-random-chars
AI_SCIENTIST_APP_PASSWORD=replace-with-operator-password
AI_SCIENTIST_JWT_SECRET=replace-with-64-plus-random-chars

AI_SCIENTIST_JWT_TTL_SECONDS=604800
AI_SCIENTIST_COOKIE_SECURE=true
AI_SCIENTIST_COOKIE_SAMESITE=lax

MINIO_ACCESS_KEY=replace-with-minio-user
MINIO_SECRET_KEY=replace-with-32-plus-random-chars
MINIO_BUCKET=ai-scientist

AI_SCIENTIST_STORAGE_BACKEND=minio
AI_SCIENTIST_SANDBOX_BACKEND=docker
AI_SCIENTIST_SANDBOX_IMAGE=python:3.11-slim
AI_SCIENTIST_SANDBOX_CPU_QUOTA=50000
AI_SCIENTIST_SANDBOX_MEMORY_MB=512
AI_SCIENTIST_WORKER_CONCURRENCY=2

AI_SCIENTIST_AI_PROVIDER=deterministic
AI_SCIENTIST_MODEL=gpt-4.1-mini
AI_SCIENTIST_LIVE_SEARCH=0
AI_SCIENTIST_EMBEDDING_PROVIDER=local
AI_SCIENTIST_EMBEDDING_MODEL=deterministic-hash-v1
AI_SCIENTIST_PUBMED_ENABLED=false
AI_SCIENTIST_HF_ENABLED=false
AI_SCIENTIST_PWC_ENABLED=false
AI_SCIENTIST_MAX_PAPERS=6
AI_SCIENTIST_MAX_CHUNKS=8

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# Optional provider keys
# OPENAI_API_KEY=
# NCBI_API_KEY=
# HUGGINGFACE_API_TOKEN=
# PAPERSWITHCODE_API_KEY=

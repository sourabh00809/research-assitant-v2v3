AI_SCIENTIST_APP_PASSWORD=change-me
AI_SCIENTIST_ENV=development
AI_SCIENTIST_STORE_BACKEND=sqlite
AI_SCIENTIST_DB_PATH=/app/data/ai_scientist.db
DATABASE_URL=postgresql+psycopg://ai_scientist:ai_scientist@postgres:5432/ai_scientist
REDIS_URL=redis://redis:6379/0
AI_SCIENTIST_STORAGE_DIR=/app/storage
AI_SCIENTIST_STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-scientist
AI_SCIENTIST_JWT_SECRET=change-this-local-secret
AI_SCIENTIST_JWT_TTL_SECONDS=604800
AI_SCIENTIST_COOKIE_SECURE=false
AI_SCIENTIST_COOKIE_SAMESITE=lax
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
AI_SCIENTIST_SANDBOX_BACKEND=docker
AI_SCIENTIST_SANDBOX_IMAGE=python:3.11-slim
AI_SCIENTIST_SANDBOX_CPU_QUOTA=50000
AI_SCIENTIST_SANDBOX_MEMORY_MB=512
AI_SCIENTIST_WORKER_CONCURRENCY=2
AI_SCIENTIST_AI_PROVIDER=deterministic
AI_SCIENTIST_MODEL=gpt-4.1-mini
AI_SCIENTIST_LIVE_SEARCH=0
AI_SCIENTIST_EMBEDDING_PROVIDER=local
AI_SCIENTIST_EMBEDDING_MODEL=deterministic-hash-v1
AI_SCIENTIST_PUBMED_ENABLED=false
AI_SCIENTIST_HF_ENABLED=false
AI_SCIENTIST_PWC_ENABLED=false
AI_SCIENTIST_MAX_PAPERS=6
AI_SCIENTIST_MAX_CHUNKS=8
